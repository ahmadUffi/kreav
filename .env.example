# Kreav — deployment environment variables (root).
# Copy to `.env` (gitignored) and adjust as needed.
# Read by docker compose (docker-compose.yml) via interpolation.
#
# PostgreSQL is on Neon (managed) — configured in backend/.env (DATABASE_URL),
# not here. There is no local Postgres service anymore.

# ---- Deployment: domains (Caddy reverse proxy) ----
# Caddy issues TLS certs for these automatically. DNS A-records must point to
# the server before the stack comes up.
APP_DOMAIN=kreav.space          # frontend
API_DOMAIN=api.kreav.space      # backend API
FUTURE_DOMAIN=app.kreav.space   # reserved — not yet routed (see Caddyfile)

# ---- Frontend build ----
# Baked into the Next.js client bundle at build time (docker-compose build arg).
# Must be the public URL of the backend.
NEXT_PUBLIC_API_URL=https://api.kreav.space

# ---- Stellar Explorer (BE-010) ----
EXPLORER_URL=https://stellar.expert/explorer/testnet
