# Kreav — local development environment variables.
# Copy to `.env` (gitignored) and adjust as needed.
# Read by docker compose (compose.yml) via interpolation.

# ---- PostgreSQL (kreav-db service) ----
POSTGRES_USER=kreav
POSTGRES_PASSWORD=kreav
POSTGRES_DB=kreav
POSTGRES_PORT=5432

# ---- Backend (backend/.env) ----
# The backend reads its own backend/.env; this is the connection string it uses.
# Mirrored here for convenience. Keep the credentials in sync with POSTGRES_* above.
DATABASE_URL=postgresql://kreav:kreav@localhost:5432/kreav?schema=public
