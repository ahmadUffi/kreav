# ---- Application ----
NODE_ENV=development
PORT=3000

# ---- Database (BE-002) ----
DATABASE_URL=postgresql://kreav:kreav@localhost:5432/kreav?schema=public

# ---- Auth (Fase 1) ----
# Signing secret for session JWTs (register + SEP-10 wallet login).
# Optional in dev (falls back to a dev-only default with a boot warning);
# REQUIRED in production. Use a long random string (>= 16 chars).
JWT_SECRET=

# ---- GCash Webhook (BE-005, audit #11) ----
# HMAC-SHA256 secret used to verify POST /webhooks/gcash signatures.
# Leave empty in dev (webhook accepts unsigned); set a real secret before the
# on-stage demo so a forged payment can't trigger a settlement.
GCASH_WEBHOOK_SECRET=

# ---- Stellar Integration (BE-007+) — Testnet ----
# RPC/Horizon endpoints + platform account for the settlement pipeline.
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
PLATFORM_WALLET_ADDRESS=
PLATFORM_WALLET_SECRET=
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
USDC_ASSET_CODE=USDC
# Deployed Kreav Settlement (revenue-split) contract (C...) — NOT the USDC SAC.
SPLIT_CONTRACT_ID=

# ---- Stellar Explorer (BE-010) ----
# Block explorer base URL for transaction links. Defaults to stellar.expert testnet.
# Change to "https://stellar.expert/explorer/public" for mainnet/production.
EXPLORER_URL=https://stellar.expert/explorer/testnet

# ---- Email delivery (product download link) ----
# Resend API key for transactional email. Leave empty in dev/testnet — emails
# are logged instead of sent (product delivery still records NotificationLog).
RESEND_API_KEY=
# From address for outgoing email. MUST be an address on a domain you've verified
# at resend.com/domains — otherwise Resend only allows sending to your own account
# email (403 validation_error). The shared onboarding@resend.dev is dev-only.
RESEND_FROM=Kreav <hello@kreav.space>

# ---- Demo mode ----
# When true, exposes POST /orders/:id/simulate-payment so buyers/judges can
# complete a purchase in-app without a real PSP. Defaults on except in
# production. Set to "false" for production.
DEMO_MODE=true

# ---- SEP-24 Anchor Off-ramp (Fase 2A) ----
# Enables the real SEP-24 withdrawal against a Stellar anchor. When off, the
# /withdrawals/anchor/* routes return 403 and the simulated withdrawal is used.
# Off by default so nothing breaks if the anchor is down.
ANCHOR_ENABLED=false
# Endpoints default to the SDF test anchor; override only for a different anchor:
# ANCHOR_WEB_AUTH_URL=https://testanchor.stellar.org/auth
# ANCHOR_TRANSFER_SERVER_URL=https://testanchor.stellar.org/sep24
# ANCHOR_HOME_DOMAIN=testanchor.stellar.org
